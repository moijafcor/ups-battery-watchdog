[Unit]
Description=UPS battery watchdog
Documentation=https://github.com/moijafcor/ups-battery-watchdog
After=apcupsd.service network.target
Wants=apcupsd.service

[Service]
Type=oneshot
ExecStart=/usr/bin/python3 /opt/ups-battery-watchdog/ups_battery_watchdog.py \
  --host forgeworkstation \
  --delay 5 \
  --timeleft-min 8 \
  --log-file /var/log/ups-battery-watchdog.log

[Install]
WantedBy=multi-user.target
